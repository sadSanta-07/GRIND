#include <iostream>
#include <vector>
using namespace std;

class Solution
{

public:
    bool isValid(int i,
                 int j,
                 const vector<vector<int>> &maze,
                 const vector<vector<int>> &vis)
    {
        int n = maze.size();
        return i >= 0 && j >= 0 && i < n && j < n && maze[i][j] == 1 && !vis[i][j];
    }

    void solve(int i,
               int j,
               vector<vector<int>> &maze,
               vector<vector<int>> &vis,
               string path,
               vector<string> &ans)
    {
        int n = maze.size();

        if (i == n - 1 && j == n - 1)
        {
            ans.push_back(path);
            return;
        }

        vis[i][j] = 1;

        if (isValid(i + 1, j, maze, vis))
            solve(i + 1, j, maze, vis, path + 'D', ans);

        if (isValid(i, j + 1, maze, vis))
            solve(i, j + 1, maze, vis, path + 'R', ans);

        if (isValid(i, j - 1, maze, vis))
            solve(i, j - 1, maze, vis, path + 'L', ans);

        if (isValid(i - 1, j, maze, vis))
            solve(i - 1, j, maze, vis, path + 'U', ans);

        vis[i][j] = 0;
    }
};